 702        
 703        %put NOTE: Median imputation values:;
 NOTE: Median imputation values:
 704        %put NOTE:   Sedentary min = &med_sed. | Calories = &med_cal.;
 NOTE:   Sedentary min = 300 | Calories = 1845.5
 705        %put NOTE:   Fiber g       = &med_fib. | Sugar g  = &med_sug.;
 NOTE:   Fiber g       = 14.1 | Sugar g  = 81.215
 706        %put NOTE:   PIR           = &med_pir.;
 NOTE:   PIR           = 2.8
 707        
 708        /* ---- 5.2  Derive composite features ------------------------------------ */
 709        data work.analytic_fe;
 710            set work.analytic;
 711        
 712            /* Median imputation for variables with moderate missingness */
 713            if missing(sed_min)  then sed_min  = &med_sed.;
 714            if missing(calories) then calories = &med_cal.;
 715            if missing(fiber_g)  then fiber_g  = &med_fib.;
 716            if missing(sugar_g)  then sugar_g  = &med_sug.;
 717            if missing(pir)      then pir      = &med_pir.;
 718        
 719            /* Zero-fill activity days (no data = no activity reported) */
 720            if missing(vig_days)    then vig_days    = 0;
 721            if missing(mod_days)    then mod_days    = 0;
 722            if missing(vig_min_wk)  then vig_min_wk  = 0;
 723            if missing(mod_min_wk)  then mod_min_wk  = 0;
 724            if missing(met_min_wk)  then met_min_wk  = 0;
 725            if missing(active_days) then active_days = 0;
 726            if missing(meets_pa_guidelines) then meets_pa_guidelines = 0;
 727            if missing(flag_high_sugar)     then flag_high_sugar      = 0;
 728            if missing(flag_low_fiber)      then flag_low_fiber       = 0;
 729            if missing(flag_htn)            then flag_htn             = 0;
 730        
 731            /* --- Composite activity score (0-10 scale) ---
 732               Based on MET-min/week (CDC guideline = 600 MET-min/week = score 5).
 733               Penalises high sedentary time. Capped at 10, floored at 0.          */
 734            if not missing(met_min_wk) then
 735                activity_score = min(10, max(0, (met_min_wk / 120) - (sed_min / 240)));
 736            else
 737                activity_score = max(0, -(sed_min / 240));   /* activity unknown   */
 738        
 739            /* --- Simple diet quality score (0-4 points) ---
 740               +1 for adequate fiber (>=15g), +1 for low sugar (<50g),
 741               +1 for adequate protein (>=15% calories), +1 for low sodium (<2300mg) */
 742            diet_score = (fiber_g >= 15)
 743                       + (sugar_g < 50)
 744                       + (pct_protein >= 15)
 745                       + (sodium_mg < 2300);
 746        
 747            /* --- Sedentary behavior flag: >= 8 hours/day sitting ---------------  */
 748            flag_high_sedentary = (sed_min >= 480);
 749        
 750            /* --- Income category from poverty-to-income ratio ------------------- */
 751            length income_cat $15;
 752            if      pir < 1.0 then income_cat = 'Below Poverty';
 753            else if pir < 2.0 then income_cat = 'Low Income';
 754            else if pir < 4.0 then income_cat = 'Middle Income';
 755            else                    income_cat = 'High Income';
 756        
 757            /* --- Log-transform sedentary minutes for modeling (right-skewed) --- */
 758            if sed_min > 0 then log_sed = log(sed_min);
 759        
 760            label activity_score      = 'Composite Activity Score (0-10)'
 761                  diet_score          = 'Diet Quality Score (0-4)'
 762                  flag_high_sedentary = 'High Sedentary Behavior (>=8 hr/day)'
 763                  income_cat          = 'Income Category'
 764                  log_sed             = 'Log(Sedentary Minutes)';
 765        run;
 
