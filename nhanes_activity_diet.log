 892        title2 "Section 7 - Model Evaluation";
 893        
 894        /* ---- 7.1  AUC ----------------------------------------------------------- */
 895        /* OUTROC= creates sensitivity and 1-specificity values, but not a _C_ column.
 896           Compute AUC manually using the trapezoidal rule over the ROC curve. */
 897        proc sort data=work.roc_full out=work.roc_sorted;
 898            by _1mspec_;
 899        run;
 
 NOTE: There were 22814 observations read from the data set WORK.ROC_FULL.
 NOTE: The data set WORK.ROC_SORTED has 22814 observations and 8 variables.
 NOTE: PROCEDURE SORT used (Total process time):
