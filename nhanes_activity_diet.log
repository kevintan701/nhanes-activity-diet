 900        
 901        data work.auc_full;
 902            set work.roc_sorted end=last;
 903            retain prev_x prev_y auc 0;
 904        
 905            x = _1mspec_;     /* false positive rate = 1 - specificity */
 906            y = _sensit_;     /* true positive rate = sensitivity */
 907        
 908            if _n_ = 1 then do;
 909                prev_x = x;
 910                prev_y = y;
 911            end;
 912            else do;
 913                auc + (x - prev_x) * (y + prev_y) / 2;
 914                prev_x = x;
 915                prev_y = y;
 916            end;
 917        
 918            if last then do;
 919                auc = round(auc, 0.001);
 920                output;
 921            end;
 922        
 923            keep auc;
 924        run;
 
