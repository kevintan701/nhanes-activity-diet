 70         /******************************************************************************/
 71         /*  PROJECT:  Diet, Physical Activity, and Obesity Risk Analysis              */
 72         /*  PROGRAM:  nhanes_activity_diet.sas                                        */
 73         /*  AUTHOR:   Yuntao (Kevin) Tan                                              */
 74         /*  DATE:     2026-02-02                                                      */
 75         /*                                                                            */
 76         /*                                                                            */
 77         /*  DESCRIPTION:                                                              */
 78         /*    Analysis of CDC NHANES (Aug 2021-Aug 2023) data to examine how daily    */
 79         /*    dietary intake and physical activity patterns relate to obesity and      */
 80         /*    metabolic health in U.S. adults. Covers multi-file XPT import, data     */
 81         /*    cleaning, feature engineering, EDA, logistic regression, and            */
 82         /*    a reusable profiling macro.                                             */
 83         /*                                                                            */
 84         /*  DATA SOURCE:                                                              */
 85         /*    CDC National Health and Nutrition Examination Survey (NHANES)           */
 86         /*    Cycle: August 2021 - August 2023 (suffix _L)                           */
 87         /*    URL:   https://wwwn.cdc.gov/nchs/nhanes/                               */
 88         /*                                                                            */
 89         /*    Files needed (download as XPT and upload to SAS OnDemand):             */
 90         /*      DEMO_L.XPT  - Demographics (age, sex, race, income)                  */
 91         /*      BMX_L.XPT   - Body Measures (height, weight, BMI, waist)             */
 92         /*      PAQ_L.XPT   - Physical Activity questionnaire (adults 18+)           */
 93         /*      DR1TOT_L.XPT- Dietary Recall Day 1 (calories, protein, fat, etc.)   */
 94         /*      BPXO_L.XPT  - Blood Pressure (systolic/diastolic)                    */
 95         /*                                                                            */
 96         /*  RESEARCH QUESTIONS:                                                       */
 97         /*    1. Do physically active adults have lower obesity prevalence?           */
 98         /*    2. Which dietary factors (calories, protein, sugar, fiber) are most    */
 99         /*       associated with obesity status after adjusting for demographics?     */
 100        /*    3. Can a simple model predict obesity from activity + diet alone?       */
 101        /*                                                                            */
 102        /******************************************************************************/
 103        
 104        
 105        /******************************************************************************/
 106        /* SECTION 0: GLOBAL SETUP                                                    */
 107        /******************************************************************************/
 108        
 109        /* Export traditional SAS listing output for .lst submission */
 110        ods listing file="/home/u64415572/nhanes-activity-diet/nhanes_activity_diet.lst";
 111        
 112        options nodate nonumber linesize=120 pagesize=60;
 113        
 114        /* ---- Update this path to your SAS OnDemand upload folder --------------- */
 115        %let DATAPATH = /home/u64415572/nhanes-activity-diet;
 116        
 117        /* ---- Analysis parameters ----------------------------------------------- */
 118        %let MIN_AGE   = 18;     /* Restrict to adults                              */
 119        %let SEED      = 20260425;
 120        %let LOGIT_SL  = 0.05;
 121        
 122        title1 "NHANES 2021-2023: Diet, Physical Activity, and Obesity";
 123        title2 "Yuntao (Kevin) Tan  |  Independent Portfolio  |  CDC Public-Use Data Analysis";
 124        
 125        
 126        /******************************************************************************/
 127        /* SECTION 1: MACRO LIBRARY                                                   */
 128        /*                                                                            */
 129        /*   %IMPORT_XPT     - Import a single NHANES XPT file into WORK             */
 130        /*   %SUMMARIZE_VAR  - Univariate stats for a numeric variable                */
 131        /*   %FREQ_TABLE     - One-way frequency for a categorical variable           */
 132        /*   %PROFILE_GROUP  - Compare key outcomes across a categorical grouping     */
 133        /******************************************************************************/
 134        
 135        /* -------------------------------------------------------------------------- */
 136        /* %IMPORT_XPT                                                                */
 137        /*   Reads a SAS transport (.XPT) file from the data folder and creates a    */
 138        /*   WORK dataset. NHANES distributes all public files in XPT format.        */
 139        /*                                                                            */
 140        /*   Parameters:                                                              */
 141        /*     FILE  = XPT filename without extension (e.g., DEMO_L)                 */
 142        /*     OUT   = Name of output WORK dataset                                   */
 143        /* -------------------------------------------------------------------------- */
 144        %macro import_xpt(file=, out=);
 145        
 146            /* PROC COPY via xport libname is the most reliable XPT import method.
 147               The filename reference is used only as a fallback check.
 148               Note: Linux filesystems are case-sensitive; files on disk are .xpt  */
 149            libname xptlib xport "&DATAPATH./&file..xpt" access=readonly;
 150        
 151            proc copy inlib=xptlib outlib=work;
 152                select &file.;
 153            run;
 154        
 155            /* Rename the copied dataset to the requested output name if different */
 156            %if %upcase(&file.) ne %upcase(&out.) %then %do;
 157                proc datasets library=work nolist;
 158                    change &file. = &out.;
 159                quit;
 160            %end;
 161        
 162            libname xptlib clear;
 163        
 164            proc sql noprint;
 165                select count(*) into :_nobs trimmed from work.&out.;
 166            quit;
 167            %put NOTE: [import_xpt] &file..xpt -> WORK.&out. | N = &_nobs. rows;
 168        
 169        %mend import_xpt;
 170        
 171        
 172        /* -------------------------------------------------------------------------- */
 173        /* %SUMMARIZE_VAR                                                             */
 174        /*   Descriptive statistics for a single numeric variable.                   */
 175        /* -------------------------------------------------------------------------- */
 176        %macro summarize_var(dsn=, var=, label=);
 177        
 178            %if %length(&label.) = 0 %then %let label = &var.;
 179        
 180            proc means data=&dsn. n nmiss mean std min p25 median p75 max maxdec=2;
 181                var &var.;
 182                label &var. = "&label.";
 183                title3 "Summary: &label.";
 184            run;
 185        
 186        %mend summarize_var;
 187        
 188        
 189        /* -------------------------------------------------------------------------- */
 190        /* %FREQ_TABLE                                                                */
 191        /*   Frequency distribution for a categorical variable.                      */
 192        /* -------------------------------------------------------------------------- */
 193        %macro freq_table(dsn=, var=, label=);
 194        
 195            %if %length(&label.) = 0 %then %let label = &var.;
 196        
 197            proc freq data=&dsn.;
 198                tables &var. / missing nocum;
 199                label &var. = "&label.";
 200                title3 "Frequency: &label.";
 201            run;
 202        
 203        %mend freq_table;
 204        
 205        
 206        /* -------------------------------------------------------------------------- */
 207        /* %PROFILE_GROUP                                                             */
 208        /*   Compares means of a continuous outcome across levels of a grouping       */
 209        /*   variable. Used to profile BMI, calorie intake, and activity by group.   */
 210        /*                                                                            */
 211        /*   Parameters:                                                              */
 212        /*     DSN      = Input dataset                                               */
 213        /*     GROUPVAR = Categorical grouping variable                               */
 214        /*     OUTVARS  = Space-separated list of numeric outcome variables           */
 215        /*     TITLE    = Descriptive title for the output                           */
 216        /* -------------------------------------------------------------------------- */
 217        %macro profile_group(dsn=, groupvar=, outvars=, title=);
 218        
 219            proc means data=&dsn. mean std median n maxdec=2 nway;
 220                class &groupvar.;
 221                var &outvars.;
 222                title3 "&title.";
 223                title4 "Grouped by: &groupvar.";
 224            run;
 225        
 226        %mend profile_group;
