 780        /******************************************************************************/
 781        /* SECTION 6: LOGISTIC REGRESSION — PREDICTORS OF OBESITY                    */
 782        /*   Outcome: obese (BMI >= 30, binary 1/0)                                  */
 783        /*   Model A: Physical activity predictors only                               */
 784        /*   Model B: Dietary predictors only                                         */
 785        /*   Model C: Full model — activity + diet + demographics                    */
 786        /*                                                                            */
 787        /*   Note on survey weights: NHANES uses complex survey design. Proper        */
 788        /*   national estimates require PROC SURVEYLOGISTIC with exam_wt. For        */
 789        /*   a portfolio demonstration, we show both unweighted PROC LOGISTIC        */
 790        /*   (simpler, clear code) and note the survey-weighted approach.            */
 791        /******************************************************************************/
 792        
 793        title2 "Section 6 - Logistic Regression: Predictors of Obesity";
 794        
 795        /* Keep graphics off for clean .log/.lst export in SAS Studio.
 796           This avoids image-write permission errors for generated OR plots. */
 797        ods graphics off;
 798        
 799        /* ---- Model A: Physical Activity Only ------------------------------------ */
 800        proc logistic data=work.analytic_fe descending;
 801            class activity_cat (ref='Sedentary') / param=ref;
 802            model obese(event='1') =
 803                  activity_score
 804                  meets_pa_guidelines
 805                  met_min_wk
 806                  vig_min_wk
 807                  mod_min_wk
 808                  activity_cat
 809                  sed_min
 810                  flag_high_sedentary
 811                  / clodds=wald lackfit rsquare ctable pprob=(0.3 0.4 0.5);
 812            oddsratio activity_cat / cl=wald;
 813            output out=work.scored_a p=pred_prob_a;
 814            title3 "Model A: Physical Activity Predictors of Obesity";
 815        run;
 
