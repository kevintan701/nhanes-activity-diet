 512        /* ---- 3.5  Blood pressure: mean systolic and diastolic ------------------- */
 513        data work.bp_clean;
 514            set work.bp;
 515        
 516            /* BPXO_L contains oscillometric readings; use first reading */
 517            sbp = BPXOSY1;   /* Systolic  */
 518            dbp = BPXODI1;   /* Diastolic */
 519        
 520            /* Hypertension flag: SBP >= 130 or DBP >= 80 (ACC/AHA 2017 definition) */
 521            if not missing(sbp) and not missing(dbp) then
 522                flag_htn = (sbp >= 130 or dbp >= 80);
 523        
 524            where not missing(BPXOSY1);
 525            keep SEQN sbp dbp flag_htn;
 526        
 527            label sbp      = 'Systolic Blood Pressure (mmHg)'
 528                  dbp      = 'Diastolic Blood Pressure (mmHg)'
 529                  flag_htn = 'Hypertension (SBP>=130 or DBP>=80)';
 530        run;
 
