 458        /* ---- 3.4  Dietary recall Day 1: key nutrients --------------------------- */
 459        /*   DR1TOT_L key variables:                                                 */
 460        /*     DR1TKCAL - Total calories (kcal)                                      */
 461        /*     DR1TPROT - Protein (g)                                                */
 462        /*     DR1TTFAT - Total fat (g)                                              */
 463        /*     DR1TSFAT - Saturated fat (g)                                          */
 464        /*     DR1TSUGR - Total sugars (g)                                           */
 465        /*     DR1TFIBE - Dietary fiber (g)                                          */
 466        /*     DR1TSODI - Sodium (mg)                                                */
 467        /*     DR1DRSTZ - Dietary recall status (1=reliable complete)                */
 468        /* -------------------------------------------------------------------------- */
 469        data work.diet_clean;
 470            set work.diet;
 471        
 472            /* Keep only reliable, complete dietary recalls */
 473            where DR1DRSTZ = 1;
 474        
 475            calories  = DR1TKCAL;
 476            protein_g = DR1TPROT;
 477            fat_g     = DR1TTFAT;
 478            satfat_g  = DR1TSFAT;
 479            sugar_g   = DR1TSUGR;
 480            fiber_g   = DR1TFIBE;
 481            sodium_mg = DR1TSODI;
 482        
 483            /* Nutrient density: protein as % of total calories (4 kcal/g) */
 484            if calories > 0 then pct_protein = (protein_g * 4 / calories) * 100;
 485        
 486            /* Flag high sugar intake (> 100g/day) */
 487            flag_high_sugar = (sugar_g > 100);
 488        
 489            /* Flag low fiber intake (< 15g/day; US median is ~16g) */
 490            flag_low_fiber  = (fiber_g < 15);
 491        
 492            /* Log-transform calories for modeling (right-skewed) */
 493            if calories > 0 then log_calories = log(calories);
 494        
 495            keep SEQN calories protein_g fat_g satfat_g sugar_g fiber_g sodium_mg
 496                 pct_protein flag_high_sugar flag_low_fiber log_calories;
 497        
 498            label calories        = 'Total Calories (kcal/day)'
 499                  protein_g       = 'Protein (g/day)'
 500                  fat_g           = 'Total Fat (g/day)'
 501                  satfat_g        = 'Saturated Fat (g/day)'
 502                  sugar_g         = 'Total Sugars (g/day)'
 503                  fiber_g         = 'Dietary Fiber (g/day)'
 504                  sodium_mg       = 'Sodium (mg/day)'
 505                  pct_protein     = 'Protein as % of Calories'
 506                  flag_high_sugar = 'High Sugar Intake (>100g/day)'
 507                  flag_low_fiber  = 'Low Fiber Intake (<15g/day)'
 508                  log_calories    = 'Log(Calories)';
 509        run;
 
