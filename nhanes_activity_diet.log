 258        /******************************************************************************/
 259        /* SECTION 3: DATA CLEANING AND COHORT SELECTION                              */
 260        /*   3.1  Keep adults 18+ with complete examination data                      */
 261        /*   3.2  Recode categorical variables with interpretable labels              */
 262        /*   3.3  Merge all five files on SEQN                                        */
 263        /*   3.4  Flag key missing variables                                          */
 264        /******************************************************************************/
 265        
 266        title2 "Section 3 - Data Cleaning and Cohort Selection";
 267        
 268        /* ---- 3.1  Adult demographics: keep 18+, extract key variables ----------- */
 269        data work.demo_clean;
 270            set work.demo;
 271        
 272            /* Restrict to adults */
 273            where RIDAGEYR >= &MIN_AGE.;
 274        
 275            /* Rename for clarity */
 276            age     = RIDAGEYR;
 277            sex     = RIAGENDR;     /* 1=Male 2=Female                               */
 278            pir     = INDFMPIR;     /* Poverty-to-income ratio; higher=wealthier     */
 279        
 280            /* Race/ethnicity: recode to readable label */
 281            length race_label $25;
 282            select (RIDRETH3);
 283                when (1) race_label = 'Mexican American';
 284                when (2) race_label = 'Other Hispanic';
 285                when (3) race_label = 'Non-Hispanic White';
 286                when (4) race_label = 'Non-Hispanic Black';
 287                when (6) race_label = 'Non-Hispanic Asian';
 288                otherwise race_label = 'Other/Multiracial';
 289            end;
 290        
 291            /* Sex label */
 292            length sex_label $8;
 293            if sex = 1 then sex_label = 'Male';
 294            else if sex = 2 then sex_label = 'Female';
 295        
 296            /* Age groups */
 297            length age_group $10;
 298            if      age < 30 then age_group = '18-29';
 299            else if age < 45 then age_group = '30-44';
 300            else if age < 60 then age_group = '45-59';
 301            else                  age_group = '60+';
 302        
 303            /* MEC exam weight for survey-weighted analyses */
 304            exam_wt = WTMEC2YR;
 305        
 306            keep SEQN age sex sex_label race_label age_group pir exam_wt;
 307        
 308            label age        = 'Age (years)'
 309                  sex_label  = 'Sex'
 310                  race_label = 'Race/Ethnicity'
 311                  age_group  = 'Age Group'
 312                  pir        = 'Poverty-to-Income Ratio'
 313                  exam_wt    = 'MEC Exam Sample Weight';
 314        run;
 
