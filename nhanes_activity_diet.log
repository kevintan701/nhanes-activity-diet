 317        /* ---- 3.2  Body measures: BMI, waist circumference ----------------------- */
 318        data work.bmx_clean;
 319            set work.bmx;
 320            where BMXBMI > 0;       /* Exclude missing/invalid BMI                  */
 321        
 322            bmi         = BMXBMI;
 323            waist_cm    = BMXWAIST;
 324            weight_kg   = BMXWT;
 325            height_cm   = BMXHT;
 326        
 327            /* WHO obesity classification */
 328            length bmi_cat $20;
 329            if      bmi < 18.5 then bmi_cat = 'Underweight';
 330            else if bmi < 25.0 then bmi_cat = 'Normal';
 331            else if bmi < 30.0 then bmi_cat = 'Overweight';
 332            else                    bmi_cat = 'Obese';
 333        
 334            /* Binary outcome: obese vs not (BMI >= 30) */
 335            obese = (bmi >= 30);
 336        
 337            keep SEQN bmi waist_cm weight_kg height_cm bmi_cat obese;
 338        
 339            label bmi        = 'Body Mass Index (kg/m2)'
 340                  waist_cm   = 'Waist Circumference (cm)'
 341                  weight_kg  = 'Weight (kg)'
 342                  height_cm  = 'Height (cm)'
 343                  bmi_cat    = 'BMI Category'
 344                  obese      = 'Obese (BMI >= 30)';
 345        run;
 
