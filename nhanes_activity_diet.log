 533        /* ---- 3.6  Merge all five cleaned files on SEQN -------------------------- */
 534        proc sql;
 535            create table work.analytic as
 536            select
 537                d.SEQN,
 538                d.age,
 539                d.sex,
 540                d.sex_label,
 541                d.race_label,
 542                d.age_group,
 543                d.pir,
 544                d.exam_wt,
 545        
 546                /* Body measures */
 547                b.bmi,
 548                b.waist_cm,
 549                b.weight_kg,
 550                b.bmi_cat,
 551                b.obese,
 552        
 553                /* Physical activity */
 554                p.vig_days,
 555                p.mod_days,
 556                p.vig_min_wk,
 557                p.mod_min_wk,
 558                p.met_min_wk,
 559                p.sed_min,
 560                p.active_days,
 561                p.meets_pa_guidelines,
 562                p.activity_cat,
 563        
 564                /* Dietary intake */
 565                dt.calories,
 566                dt.protein_g,
 567                dt.fat_g,
 568                dt.satfat_g,
 569                dt.sugar_g,
 570                dt.fiber_g,
 571                dt.sodium_mg,
 572                dt.pct_protein,
 573                dt.flag_high_sugar,
 574                dt.flag_low_fiber,
 575                dt.log_calories,
 576        
 577                /* Blood pressure */
 578                bp.sbp,
 579                bp.dbp,
 580                bp.flag_htn
 581        
 582            from      work.demo_clean  d
 583            left join work.bmx_clean   b  on d.SEQN = b.SEQN
 584            left join work.paq_clean   p  on d.SEQN = p.SEQN
 585            left join work.diet_clean  dt on d.SEQN = dt.SEQN
 586            left join work.bp_clean    bp on d.SEQN = bp.SEQN
 587        
 588            /* Require BMI for the outcome variable */
 589            where b.bmi is not missing
 590            order by d.SEQN;
