 681        title2 "Section 5 - Feature Engineering";
 682        
 683        /* ---- 5.1  Compute medians for imputation -------------------------------- */
 684        %macro impute_median(dsn=, var=, mvar=);
 685            %global &mvar.;
 686            proc means data=&dsn. median noprint;
 687                var &var.;
 688                output out=_med median=med_val;
 689            run;
 690            data _null_;
 691                set _med;
 692                call symputx("&mvar.", med_val, 'G');
 693            run;
 694            proc datasets library=work nolist; delete _med; quit;
 695        %mend impute_median;
