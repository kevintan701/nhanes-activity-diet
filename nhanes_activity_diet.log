 347        
 348        /* ---- 3.3  Physical activity: moderate/vigorous frequency, sedentary time  */
 349        /*   PAQ_L variable structure changed completely in the 2021-2023 cycle.     */
 350        /*   The previous yes/no + days/week format was replaced with:               */
 351        /*     PAD790Q / PAD790U - Moderate LTPA frequency + unit (D/W/M/Y)         */
 352        /*     PAD800            - Minutes per session: moderate                     */
 353        /*     PAD810Q / PAD810U - Vigorous LTPA frequency + unit (D/W/M/Y)         */
 354        /*     PAD820            - Minutes per session: vigorous                     */
 355        /*     PAD680            - Minutes sedentary per day (unchanged)             */
 356        /*                                                                           */
 357        /*   CDC PA guideline (2018): >= 150 min/week moderate-equivalent activity   */
 358        /*   MET-minutes/week = (mod_min_wk * 4) + (vig_min_wk * 8)                 */
 359        /*   Guideline met if MET-min/week >= 600                                    */
 360        /* -------------------------------------------------------------------------- */
 361        data work.paq_clean;
 362            set work.paq;
 363        
 364            /* --- Step 1: Convert moderate frequency to sessions per week ---------- */
 365            /* Unit codes: D=Day, W=Week, M=Month, Y=Year                            */
 366            if PAD790Q in (7777, 9999, .) or missing(PAD790U) then mod_freq_wk = .;
 367            else do;
 368                select (PAD790U);
 369                    when ('D') mod_freq_wk = PAD790Q * 7;    /* sessions/day -> /week */
 370                    when ('W') mod_freq_wk = PAD790Q;
 371                    when ('M') mod_freq_wk = PAD790Q / 4.33;
 372                    when ('Y') mod_freq_wk = PAD790Q / 52;
 373                    otherwise  mod_freq_wk = .;
 374                end;
 375            end;
 376            /* No moderate activity reported (frequency = 0) */
 377            if PAD790Q = 0 then mod_freq_wk = 0;
 378        
 379            /* --- Step 2: Convert vigorous frequency to sessions per week ---------- */
 380            if PAD810Q in (7777, 9999, .) or missing(PAD810U) then vig_freq_wk = .;
 381            else do;
 382                select (PAD810U);
 383                    when ('D') vig_freq_wk = PAD810Q * 7;
 384                    when ('W') vig_freq_wk = PAD810Q;
 385                    when ('M') vig_freq_wk = PAD810Q / 4.33;
 386                    when ('Y') vig_freq_wk = PAD810Q / 52;
 387                    otherwise  vig_freq_wk = .;
 388                end;
 389            end;
 390            if PAD810Q = 0 then vig_freq_wk = 0;
 391        
 392            /* --- Step 3: Total minutes per week for each intensity ---------------- */
 393            /* Minutes per session (PAD800, PAD820): already in minutes              */
 394            if not missing(mod_freq_wk) and not missing(PAD800) and PAD800 < 9999
 395                then mod_min_wk = mod_freq_wk * PAD800;
 396            else if mod_freq_wk = 0
 397                then mod_min_wk = 0;
 398            else mod_min_wk = .;
 399        
 400            if not missing(vig_freq_wk) and not missing(PAD820) and PAD820 < 9999
 401                then vig_min_wk = vig_freq_wk * PAD820;
 402            else if vig_freq_wk = 0
 403                then vig_min_wk = 0;
 404            else vig_min_wk = .;
 405        
 406            /* --- Step 4: Approximate days/week for backward compatibility ----------
 407               Round frequency to nearest whole day, capped at 7.                   */
 408            if not missing(mod_freq_wk) then mod_days = min(7, round(mod_freq_wk));
 409            else mod_days = .;
 410        
 411            if not missing(vig_freq_wk) then vig_days = min(7, round(vig_freq_wk));
 412            else vig_days = .;
 413        
 414            /* Total active days (capped at 7) */
 415            if not missing(vig_days) and not missing(mod_days) then
 416                active_days = min(7, vig_days + mod_days);
 417        
 418            /* --- Step 5: Sedentary minutes per day (variable unchanged) ----------- */
 419            if PAD680 in (9999, .) then sed_min = .;
 420            else sed_min = min(PAD680, 1200);   /* cap at 20 hours */
 421        
 422            /* --- Step 6: CDC PA guidelines (2018 Physical Activity Guidelines)------
 423               Guideline: >= 150 min/week moderate OR >= 75 min/week vigorous,
 424               or equivalent combination. Use MET-min approach:
 425                 MET-min/week = (mod_min_wk * 4.0) + (vig_min_wk * 8.0) >= 600    */
 426            if not missing(mod_min_wk) or not missing(vig_min_wk) then do;
 427                met_min_wk = coalesce(mod_min_wk, 0) * 4.0
 428                           + coalesce(vig_min_wk, 0) * 8.0;
 429                meets_pa_guidelines = (met_min_wk >= 600);
 430            end;
 431            else do;
 432                met_min_wk = .;
 433                meets_pa_guidelines = .;
 434            end;
 435        
 436            /* --- Step 7: Activity level category ---------------------------------- */
 437            length activity_cat $12;
 438            if      vig_min_wk >= 75  or met_min_wk >= 600 then activity_cat = 'Active';
 439            else if mod_min_wk > 0    or vig_min_wk > 0    then activity_cat = 'Low Active';
 440            else if mod_min_wk = 0    and vig_min_wk = 0   then activity_cat = 'Sedentary';
 441            else                                                 activity_cat = 'Unknown';
 442        
 443            keep SEQN vig_days mod_days vig_min_wk mod_min_wk met_min_wk
 444                 sed_min active_days meets_pa_guidelines activity_cat;
 445        
 446            label vig_days           = 'Vigorous Activity Days/Week (approx)'
 447                  mod_days           = 'Moderate Activity Days/Week (approx)'
 448                  vig_min_wk         = 'Vigorous Activity Minutes/Week'
 449                  mod_min_wk         = 'Moderate Activity Minutes/Week'
 450                  met_min_wk         = 'Total MET-minutes/Week (mod*4 + vig*8)'
 451                  sed_min            = 'Sedentary Minutes/Day'
 452                  active_days        = 'Total Active Days/Week'
 453                  meets_pa_guidelines= 'Meets CDC PA Guidelines (MET-min >= 600)'
 454                  activity_cat       = 'Physical Activity Level';
 455        run;
 
